{
    "manifest_version": 3,
    "name": "VeriJob Scam Detector",
    "version": "1.0",
    "description": "Detects suspicious and fraudulent job postings using the VeriJob API.",
    "permissions": ["activeTab", "scripting"],
    "host_permissions": ["http://127.0.0.1:8000/*"],

    "action": {
        "default_popup": "popup.html",
        "default_icon": "Scan Job Posting"
    }
}